{
    "$schema": "https://json-schema.org",
    "title": "Server config",
    "type": "object",
    "properties":{
        "logger":{
            "type": "object",
            "maxAge":{
                "type": "integer",
                "minimum": 1,
                "maximum": 30
            },
            "maxSize":{
                "type": "integer",
                "minimum": 1,
                "maximum": 10240
            },
            "maxBackups":{
                "type": "integer",
                "minimum": 1,
                "maximum": 7
            },
            "compress":{
                "type": "boolean",
                "default": false
            },
            "required": ["maxAge", "maxSize", "maxBackups"]
        },
        "nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "ip": {
                        "type": "string",
                        "format": "ipv4"
                    },
                    "frequency": {
                        "type": "integer",
                        "minimum": 1
                    }
                },
                "required": ["ip", "frequency"],
                "additionalProperties": false
            }
        }
    },
    "required": ["nodes", "logger"]
}