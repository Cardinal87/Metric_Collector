{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Server config",
    "type": "object",
    "properties":{
        "logger":{
            "type": "object",
            "properties": {
                "maxAge":{
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 30
                },
                "maxSize":{
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10240
                },
                "maxBackups":{
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 7
                },
                "compress":{
                    "type": "boolean"
                }
            },
            "additionalProperties": false,
            "required": ["maxAge", "maxSize", "maxBackups", "compress"]
        },
        "nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "ip": {
                        "type": "string",
                        "format": "ipv4"
                    },
                    "frequency": {
                        "type": "integer",
                        "minimum": 1
                    }
                },
                "required": ["ip", "frequency"],
                "additionalProperties": false
            }
        },
        "methodConfig":{
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "properties": {
                                "service": {
                                    "type": "string"
                                },
                                "method": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "retryPolicy": {
                        "type": "object",
                        "properties": {
                            "maxAttempts": {
                                "type": "integer",
                                "minimum": 2
                            },
                            "initialBackoff": {
                                "type": "string",
                                "pattern": "^[0-9]+\\.?[0-9]*s$"
                            },
                            "maxBackoff": {
                                "type": "string",
                                "pattern": "^[0-9]+\\.?[0-9]*s$"
                            },
                            "backoffMultiplier": {
                                "type": "number",
                                "minimum": 1.0,
                                "multipleOf": 0.1
                            },
                            "retryableStatusCodes": {
                                "type": "array",
                                "minItems": 1,
                                "items": {
                                    "type": "string"
                                }
                            }
                        },
                        "required": ["maxAttempts", "initialBackoff", "maxBackoff", "backoffMultiplier", "retryableStatusCodes"],
                        "additionalProperties": false
                    }
                    
                },
                "required": ["name", "retryPolicy"],
                "additionalProperties": false
            }
        }
    },
    "required": ["nodes", "logger", "methodConfig"]
}