{
    "$schema": "https://json-schema.org",
    "title": "Server config",
    "type": "object",
    "properties":{
        "nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "ip": {
                        "type": "string",
                        "format": "ipv4"
                    },
                    "frequency": {
                        "type": "integer",
                        "minimum": 1
                    }
                },
                "required": ["ip", "frequency"],
                "additionalProperties": false
            }
        }
    },
    "required": ["nodes"]
}